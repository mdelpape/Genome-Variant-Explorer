# PostgreSQL connection string used by Prisma.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/genome_variant_explorer?schema=public"

# Optional: separate direct URL for migrations when using a pooled connection
# (e.g. PgBouncer / Neon / Supabase). Falls back to DATABASE_URL if unset.
# DIRECT_URL="postgresql://postgres:postgres@localhost:5432/genome_variant_explorer?schema=public"
